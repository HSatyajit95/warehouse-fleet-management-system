---
# CI lint gate (Phase 4.7) — kept to clang-tidy's default check set
# (clang-diagnostic-*, clang-analyzer-*), minus one check that fires a
# false positive inside BehaviorTree.CPP's vendored expected.hpp (a
# third-party header we don't control, not our code) on every BT action
# node that calls getInput<T>(). Verified clean (0 warnings) across every
# .cpp in fms_robot_agent and fms_fleet_server with this check set.
Checks: 'clang-diagnostic-*,clang-analyzer-*,-clang-analyzer-core.uninitialized.Assign'
WarningsAsErrors: '*'
HeaderFilterRegex: ''
